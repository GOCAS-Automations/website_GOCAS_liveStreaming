# Puerto del puente (por defecto 4000). El panel lo busca en http://localhost:4000
PORT=4000

# Origenes que pueden controlar el puente. Por defecto: el sitio GOCAS en Vercel + localhost.
# Ponlo en * solo para pruebas. Ejemplo con dominio propio:
# ALLOWED_ORIGINS=https://live.gocas.co,http://localhost:3000
# ALLOWED_ORIGINS=

# Ingesta RTMP de YouTube (no cambiar salvo backup)
YOUTUBE_RTMP=rtmp://a.rtmp.youtube.com/live2

# Reintentos si FFmpeg cae de forma inesperada
MAX_RESTARTS=6

# NOTA: la URL RTSP y la clave de YouTube NUNCA se guardan aqui ni en disco.
# Se envian desde el panel al iniciar cada transmision y viven solo en memoria.
