# Conexión a Supabase. Ambas variables son PÚBLICAS (viajan al navegador): NO son secretos.
# Cópialas en Vercel (Project Settings -> Environment Variables) al desplegar.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# URL del puente local (opcional). Por defecto http://localhost:4000, que es donde
# corre el puente en la PC del usuario. Normalmente NO hace falta cambiarla.
# NEXT_PUBLIC_BRIDGE_URL=http://localhost:4000
