# Conexión a Supabase. Ambas variables son PÚBLICAS (viajan al navegador): NO son secretos.
# Cópialas en Vercel (Project Settings -> Environment Variables) al desplegar.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# URL de descarga del agente (el instalador para el PC). Opcional: cuando publiques
# el ZIP (Supabase Storage, GitHub Releases, etc.) pega aquí su URL y el botón
# "Descargar agente" aparecerá en el panel.
# NEXT_PUBLIC_AGENT_DOWNLOAD_URL=https://.../GOCAS-Agente.zip
